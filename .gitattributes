# ── Force all PHP to be detected as PHP, never Hack ──────────
*.php linguist-language=PHP
*.php linguist-detectable=true

# ── Exclude non-source files from language stats ─────────────
.htaccess linguist-language=ApacheConf
apache.conf linguist-language=ApacheConf
Dockerfile linguist-detectable=true
start.sh linguist-detectable=true
schema.sql linguist-detectable=true
manifest.json linguist-detectable=true
sw.js linguist-detectable=true
pwa.js linguist-detectable=true
api.js linguist-detectable=true
